# Backend - Perfumeria A y F
# Copia este archivo como .env y completa los valores

# Puerto del servidor HTTP (default: 8080)
PORT=8080

# Ruta al archivo de base de datos SQLite (default: ./perfumeria.db)
DB_PATH=./perfumeria.db

# Secreto para firmar JWT (cambia esto en produccion)
JWT_SECRET=perfumeria-dev-secret-key-2026

# SMTP para emails de confirmacion
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuemail@gmail.com
SMTP_PASS=tu-app-password

# URL del frontend (para links en emails)
FRONTEND_URL=http://localhost:5173
