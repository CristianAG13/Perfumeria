# Frontend Environment Variables
# Copia este archivo como .env y completa los valores

# URL base de la API (opcional en desarrollo porque Vite usa proxy)
# En produccion, apunta a la URL del backend
# VITE_API_URL=http://localhost:8080

# Google OAuth Client ID (de Google Cloud Console)
# VITE_GOOGLE_CLIENT_ID=tu-client-id-aqui
